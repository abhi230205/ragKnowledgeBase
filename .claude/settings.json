{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/secret_scan.py",
            "if": "Bash(git commit*)",
            "timeout": 30,
            "statusMessage": "Scanning staged changes for secrets…"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/ruff_format.py",
            "timeout": 30,
            "statusMessage": "ruff format…"
          }
        ]
      }
    ]
  }
}
