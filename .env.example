# Copy this file to .env and fill in real values. NEVER commit .env (it is gitignored).
# Secrets can also be entered through the Settings UI, which stores them in SQLite
# and overrides the values below at runtime.

# ---- Anthropic (chat) ----
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
CHAT_MODEL=claude-sonnet-4-6

# ---- Google Drive (optional file-based service account; UI upload is the primary path) ----
# Place the JSON key in ./secrets/service_account.json (the ./secrets dir is gitignored).
GOOGLE_SERVICE_ACCOUNT_PATH=/secrets/service_account.json
DRIVE_FOLDER_ID=

# ---- Embeddings (local, open-source; NOT the Anthropic API) ----
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ---- Retrieval ----
TOP_K=5

# ---- Storage (inside container; mounted on named volumes) ----
CHROMA_PATH=/data/chroma
SQLITE_PATH=/data/app/rag.db

# ---- UI -> API ----
API_URL=http://api:8000
